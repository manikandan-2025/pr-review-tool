# =============================================================================
#  config/secrets.conf — Sensitive credentials (NEVER commit this file)
#
#  Copy this file to secrets.conf and fill in your values:
#    cp config/secrets.conf.example config/secrets.conf
#    chmod 600 config/secrets.conf
#
#  This file is gitignored. secrets.conf.example (this file) is safe to commit.
# =============================================================================

# ---------------------------------------------------------------------------
# Jira credentials — Cloud mode (JIRA_AUTH_TYPE=cloud)
# ---------------------------------------------------------------------------
# Your Atlassian account email
JIRA_USER_EMAIL=""

# Atlassian API token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=""

# ---------------------------------------------------------------------------
# Jira credentials — PAT mode (JIRA_AUTH_TYPE=pat, Jira Data Center / Server)
# ---------------------------------------------------------------------------
# Personal Access Token
# Generate at: <jira-url>/secure/ViewProfile.jspa → Personal Access Tokens
JIRA_PAT=""
